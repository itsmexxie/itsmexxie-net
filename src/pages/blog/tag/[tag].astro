---
import type { GetStaticPaths } from "astro";
import { CollectionEntry, getCollection } from "astro:content";
import IndexLayout from "../../../layouts/IndexLayout.astro";
import { PublishedPost } from "../../../types";

const { tag } = Astro.params;

async function getPublishedPosts(): Promise<PublishedPost[]> {
  return (await getCollection("blog")).filter(
    (p: CollectionEntry<"blog">) => p.data.dates,
  ) as PublishedPost[];
}

const posts = (await getPublishedPosts()).filter((post) =>
  post.data.tags?.includes(tag),
);

export const getStaticPaths = (async () => {
  const tags: Set<string> = new Set();

  for (const post of await getCollection("blog")) {
    for (const tag of post.data.tags ?? []) {
      tags.add(tag);
    }
  }

  return tags
    .values()
    .map((tag) => {
      return { params: { tag } };
    })
    .toArray();
}) satisfies GetStaticPaths;
---

<IndexLayout
  posts={posts}
  rootUrl="/blog"
  page={{ id: "blog", title: `#${tag}` }}
/>
