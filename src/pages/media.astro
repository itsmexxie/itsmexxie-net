---
import ContentLayout from "../layouts/ContentLayout.astro";

const albums = [
  "Songs for the Deaf",
  "one",
  "pretty much anything by top (Clancy, Blurryface, Trench)",
  "From Zero",
  "Meteora",
  "Hybrid Theory",
  "Sempiternal",
  "Panopticon",
];
---

<ContentLayout pageId="media" pageTitle="Media">
  <p
    >A list of media I enjoyed. Use it as a source of inspiration for yourself
    or something...<br />Warning: a lot of yuri and furry stuff (as is to be
    expected).</p
  >

  <h3>Shows</h3>
  <ul>
    <li>Arcane</li>
    <li
      >Gravity Falls (something something queer kid that grew up in the 2010s)</li
    >
    <li>Hannibal (2013)</li>
    <li>Hazbin Hotel</li>
    <li>Helluva Boss (*flexes* been watching since the pilot)</li>
    <li>
      La casa de papel (Netflix can't make me call it by the english name)
    </li>
    <li>Mr. Robot (words can't describe how much I love this fucking show)</li>
    <li>Owl House</li>
    <li>She-Ra and the Princesses of Power</li>
  </ul>

  <h3>Comics</h3>
  <ul>
    <li>
      <a href="https://rickgriffinstudios.com/ah-club/comic/001/#comic-page"
        >A&H club</a
      > (yes, it is a little cringy at times, but I enjoyed it anyway)
    </li>
    <li>
      <a
        href="https://www.webtoons.com/en/romance/night-owls-and-summer-skies/list?title_no=4747"
        >Night owls and summer skies</a
      >
    </li>
    <li>
      <a
        href="https://www.webtoons.com/en/mystery/purple-hyacinth/list?title_no=1621"
        >The Purple Hyacinth (listen to the MUSIC oh my god)</a
      >
    </li>
  </ul>

  <h3>Music</h3>
  <p
    >There is a lot of albums that I enjoy. This is a VERY shortened version of
    the full list. If you ever want music recs, come and ask!</p
  >
  <ul>
    {albums.sort().map((a) => <li>{a}</li>)}
  </ul>
</ContentLayout>
